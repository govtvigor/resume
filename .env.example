# Required for Auth.js sessions (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Contact form → email (https://resend.com — free tier, API key in dashboard)
RESEND_API_KEY=
CONTACT_EMAIL_TO=igorgovtvian9@gmail.com
# Until you verify your domain, use Resend's test sender:
CONTACT_EMAIL_FROM=Portfolio <onboarding@resend.dev>
