# Required for Auth.js sessions (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional: Slack/Discord webhook JSON { "text": "..." } for contact form delivery
# CONTACT_WEBHOOK_URL=
